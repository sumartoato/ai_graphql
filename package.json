{
  "name": "ai-graphql",
  "version": "0.2.0",
  "description": "GraphQL API production-ready dengan Node.js, Apollo Server v4, MariaDB, JWT Auth",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "setup": "npm run migrate && npm run seed",
    "lint": "eslint src/ scripts/",
    "lint:fix": "eslint src/ scripts/ --fix",
    "format": "prettier --write 'src/**/*.js' 'scripts/**/*.js'",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests"
  },
  "keywords": ["graphql", "api", "nodejs", "express", "apollo", "mariadb", "jwt"],
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@graphql-tools/merge": "^9.0.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "graphql": "^16.9.0",
    "graphql-tag": "^2.12.6",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.0"
  }
}
